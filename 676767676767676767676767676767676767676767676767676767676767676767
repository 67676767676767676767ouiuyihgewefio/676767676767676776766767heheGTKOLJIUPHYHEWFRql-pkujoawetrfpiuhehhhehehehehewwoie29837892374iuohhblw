            if flag then flag:Destroy() end
            return
        end
        local flag=Instance.new("BoolValue")
        flag.Name="UpLoop"
        flag.Parent=hrp
        task.spawn(function()
            while flag.Parent and toggled do
                hrp.CFrame=CFrame.new(hrp.Position.X,math.random(2000,9999999),hrp.Position.Z)
                task.wait(0.001)
            end
        end)
    end
end)

