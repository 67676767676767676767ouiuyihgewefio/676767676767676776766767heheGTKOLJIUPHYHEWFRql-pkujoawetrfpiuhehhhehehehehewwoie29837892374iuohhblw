local function startPredFeed(playerName)
    if predFeedConnection then predFeedConnection:Disconnect() predFeedConnection = nil end
    if not playerName or playerName == "None" then return end
    predReset()
    currentPredTarget = playerName

    local function connectToChar(char)
        if not char then return end
        local tHRP = char:FindFirstChild("HumanoidRootPart")
            or char:FindFirstChild("UpperTorso")
        if not tHRP then return end
        if predFeedConnection then predFeedConnection:Disconnect() end
        predReset()
        predFeedConnection = RunService.Heartbeat:Connect(function()
            if not KalmanPredEnabled then return end
            if currentPredTarget ~= playerName then
                predFeedConnection:Disconnect()
                predFeedConnection = nil
                return
            end
            local target = Players:FindFirstChild(playerName)
            if not target then return end
            local c = target.Character
            if not c then return end
            local hrp = c:FindFirstChild("HumanoidRootPart")
                or c:FindFirstChild("UpperTorso")
            if hrp then
                predUpdate(hrp.Position)
            end
        end)
    end

    local target = Players:FindFirstChild(playerName)
    if not target then return end
    connectToChar(target.Character)
    target.CharacterAdded:Connect(function(newChar)
        if currentPredTarget ~= playerName then return end
        newChar:WaitForChild("HumanoidRootPart", 5)
        connectToChar(newChar)
        Rayfield:Notify({
            Title = "Prediction Reset",
            Content = playerName .. " respawned, resyncing...",
            Duration = 2,
            Image = 4483362458
        })
    end)
end

local function stopPredFeed()
    if predFeedConnection then predFeedConnection:Disconnect() predFeedConnection = nil end
    predReset()
    currentPredTarget = nil
end

