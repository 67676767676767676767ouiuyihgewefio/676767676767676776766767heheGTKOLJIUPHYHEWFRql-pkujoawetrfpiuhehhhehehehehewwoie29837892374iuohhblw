local function makeNPCAura(toolName, slot, argSlot)
    Tab3:CreateToggle({
        Name="Fruit Attack ("..toolName:match("^(.-)%-")..") [NPCs]", CurrentValue=false,
        Callback=function(v)
            if v then
                if _G[slot] then task.cancel(_G[slot]) end
                _G[slot]=task.spawn(function()
                    while v do
                        task.wait(0.01)
                        local char=lp.Character
                        local hrp=char and char:FindFirstChild("HumanoidRootPart")
                        if not hrp then continue end
                        local ef=workspace:FindFirstChild("Enemies")
                        if not ef then continue end
                        for _,npc in pairs(ef:GetChildren()) do
                            local h=npc:FindFirstChild("Humanoid")
                            local nhrp=npc:FindFirstChild("HumanoidRootPart")
                            if h and nhrp and h.Health>0 and (nhrp.Position-hrp.Position).Magnitude<=50 then
                                local d=(nhrp.Position-hrp.Position).Unit
                                pcall(function()
                                    char:WaitForChild(toolName):WaitForChild("LeftClickRemote"):FireServer(vector.create(d.X,d.Y,d.Z),argSlot or 1,true)
                                end)
                            end
                        end
                    end
                end)
            else
                if _G[slot] then task.cancel(_G[slot]) _G[slot]=nil end
            end
        end,
    })
end

